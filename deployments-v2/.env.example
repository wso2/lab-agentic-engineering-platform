# =============================================================================
# App Factory — Environment Configuration
# =============================================================================
# Setup will prompt for any unset required values and auto-generate secrets.
# Press Enter to skip optional values or accept the shown default.
#
# All env vars set here flow into K8s workloads via OpenBao (for secrets)
# or directly through env-overlay templates at deploy time.
# =============================================================================

# ---- AI API Key -----------------------------------------------------------
# REQUIRED for spec generation, design, task execution (agents + remote-worker).
# Get one at: https://console.anthropic.com/settings/keys
# Skip to disable AI features — agents-service and remote-worker will start but
# every AI call will fail. Add later and re-run setup.sh to seed into OpenBao.
ANTHROPIC_API_KEY=

# ---- GitHub Integration (dev-tier org credential seed) ---------------------
# OPTIONAL — skips auto-seeding the "default" org credential. Without it, each
# user must manually connect via console: Settings → GitHub Integration → Connect.
#
# GITHUB_PLATFORM_PAT: Classic PAT scopes — repo, admin:org, admin:repo_hook
#   Fine-grained: Administration:Write, Contents:Write, Issues:Write,
#   Pull requests:Write, Webhooks:Write
#
# GITHUB_REPO_OWNER: GitHub org or user under which project repos are created.
#   e.g. "my-org" or "my-username". Only used when GITHUB_PLATFORM_PAT is set.
GITHUB_PLATFORM_PAT=
GITHUB_REPO_OWNER=

# ---- GitHub App (optional — alternative to PAT-mode connect) ----------------
# Only needed if users connect via GitHub App instead of Personal Access Token.
# Leave blank to disable App-mode; PAT-mode is always available through the UI.
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_SLUG=asdlc-platform
GITHUB_APP_PRIVATE_KEY_PATH=

# ---- Auto-generated secrets (do not set unless overriding) ------------------
# These are created on first setup.sh run. Leave blank.
GITHUB_WEBHOOK_SECRET=
OAUTH_STATE_SIGNING_KEY=
# Local: auto-provisioned smee.io channel; the host-side webhook-relay.sh
# script forwards from this URL into the in-cluster BFF. Cloud tiers set
# this to the BFF's public ingress URL (e.g. https://api.<host>/webhooks/github).
GITHUB_WEBHOOK_DELIVERY_URL=

# Task-signing PEM is a separate file at deployments-v2/keys/task-signing.pem

# ---- Thunder IDP URL -------------------------------------------------------
# Browser-accessible URL of the Thunder identity provider. Used in platform
# kustomize for CORS + OAuth redirect URIs.
# Default is correct for local k3d.
PUBLIC_THUNDER_URL=http://thunder.openchoreo.localhost:8080

# ---- Admin login (for the setup banner only) --------------------------------
# Must match the Thunder seeded admin user. Default is correct for fresh setups.
ADMIN_USERNAME=admin@openchoreo.dev
ADMIN_PASSWORD=Admin@123
