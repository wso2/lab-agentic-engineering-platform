# OpenChoreo Platform API (required)
# The backend connects to this URL for project/component operations.
PLATFORM_API_SERVICE_BASE_URL=http://api.openchoreo.localhost:8080
PLATFORM_API_SERVICE_HOST=api.openchoreo.localhost

# Thunder/Asgardeo Authentication (required)
# The console redirects to Thunder for OAuth2 login.
# You need a Thunder OAuth2 client registered for ASDLC:
#   - Grant type: authorization_code
#   - PKCE: required
#   - Public client: yes
#   - Redirect URI: http://localhost:8090
VITE_THUNDER_URL=http://thunder.openchoreo.localhost:8080
VITE_THUNDER_CLIENT_ID=asdlc-console-client
VITE_THUNDER_REDIRECT_URI=http://localhost:8090
VITE_THUNDER_SCOPES=openid profile email
VITE_THUNDER_AFTER_SIGN_IN_URL=http://localhost:8090
VITE_THUNDER_AFTER_SIGN_OUT_URL=http://localhost:8090/login
